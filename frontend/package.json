{
  "name": "img-tool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "check:canonical-host": "node scripts/check-canonical-host.mjs",
    "check:canonical-drift": "node scripts/check-canonical-drift.mjs",
    "check:blog-link-coverage": "node scripts/check-blog-link-coverage.mjs",
    "check:metadata-quality": "node scripts/check-metadata-quality.mjs",
    "check:cwv-mobile": "node scripts/check-cwv-mobile.mjs",
    "check:js-loading-strategy": "node scripts/check-js-loading-strategy.mjs",
    "check:structured-data-rich-results": "node scripts/check-structured-data-rich-results.mjs",
    "check:route-completion": "node scripts/check-route-completion-tracker.mjs",
    "check:route-completion:update": "node scripts/check-route-completion-tracker.mjs --update-checklist",
